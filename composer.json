{
  "name": "atrocore/export",
  "description": "",
  "require": {
    "atrocore/core": "~2.1.21",
    "ext-zip": "*",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "ext-curl": "*",
    "phpoffice/phpspreadsheet": "~5.3.0@stable",
    "jdorn/sql-formatter": "v1.2.16@stable"
  },
  "conflict": {
    "atrocore/pim": "<1.14.0",
    "atrocore/import": "<1.9.0"
  },
  "autoload": {
    "psr-4": {
      "Export\\": "app/"
    }
  },
  "extra": {
    "atroId": "Export",
    "name": {
