{
  "fields": {
    "zip": {
      "type": "bool",
      "view": "export:views/export-configurator-item/fields/zip"
    },
    "fileNameTemplate": {
      "type": "wysiwyg",
      "view": "export:views/export-configurator-item/fields/file-name-template",
      "notStorable": true,
      "filterDisabled": true
    },
    "name": {
      "type": "varchar",
      "view": "export:views/export-configurator-item/fields/name",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "type",
              "value": "Field"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "type",
              "value": "Field"
            }
          ]
        },
        "readOnly": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "id"
            }
          ]
        }
      }
    },
    "column": {
      "type": "varchar",
      "view": "export:views/export-configurator-item/fields/column",
      "tooltip": true
    },
    "sortOrder": {
      "type": "int"
    },
    "columnType": {
      "type": "enum",
      "required": true,
      "view": "export:views/export-configurator-item/fields/column-type",
      "options": [
        "custom",
        "name"
      ],
      "default": "custom"
    },
    "exportIntoSeparateColumns": {
      "type": "bool",
      "view": "export:views/export-configurator-item/fields/separate-columns",
      "tooltip": true
    },
    "exportBy": {
      "type": "array",
      "view": "export:views/export-configurator-item/fields/export-by"
    },
    "allAttributesCount": {
      "type": "int",
      "notStorable": true,
      "protected": true
    },
    "channels": {
      "type": "array",
      "view": "export:views/export-configurator-item/fields/channels",
      "conditionalProperties": {
        "required": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "type",
              "value": "allAttributes"
            }
          ]
        },
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "type",
              "value": "allAttributes"
            }
          ]
        }
      }
    },
    "type": {
      "type": "enum",
      "required": true,
      "options": [
        "Field",
        "allAttributes",
        "Fixed value",
        "script"
      ],
      "default": "Field",
      "conditionalProperties": {
        "protected": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "id"
            }
          ]
        }
      }
    },
    "script": {
      "type": "text",
      "view": "views/fields/script",
      "default": "{{ configuration.type }}\n{{ record.id }} {{ record.name }}",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "type",
              "value": "script"
            }
          ]
        }
      }
    },
    "exportFeedData": {
      "type": "jsonObject",
      "notStorable": true,
      "layoutListDisabled": true,
      "layoutListSmallDisabled": true,
      "layoutDetailDisabled": true,
      "layoutDetailSmallDisabled": true,
      "massUpdateDisabled": true,
      "filterDisabled": true,
      "textFilterDisabled": true,
      "exportDisabled": true,
      "importDisabled": true,
      "emHidden": true
    },
    "fieldDefs": {
      "type": "jsonObject",
      "notStorable": true,
      "layoutListDisabled": true,
      "layoutListSmallDisabled": true,
      "layoutDetailDisabled": true,
      "layoutDetailSmallDisabled": true,
      "massUpdateDisabled": true,
      "filterDisabled": true,
      "textFilterDisabled": true,
      "exportDisabled": true,
      "importDisabled": true,
      "emHidden": true
    },
    "entity": {
      "type": "varchar",
      "notStorable": true
    },
    "remove": {
      "type": "varchar",
      "notStorable": true,
      "view": "export:views/export-configurator-item/fields/remove"
    },
    "searchFilter": {
      "type": "jsonObject"
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "exportFeed": {
      "type": "link"
    },
    "mask": {
      "type": "varchar",
      "view": "export:views/export-configurator-item/fields/mask"
    },
    "editable": {
      "type": "bool",
      "notStorable": true
    },
    "offsetRelation": {
      "type": "int",
      "default": 0,
      "view": "export:views/export-configurator-item/fields/limit-relation"
    },
    "limitRelation": {
      "type": "int",
      "default": 20,
      "view": "export:views/export-configurator-item/fields/limit-relation"
    },
    "sortFieldRelation": {
      "type": "varchar",
      "view": "export:views/export-configurator-item/fields/sort-field-relation"
    },
    "sortOrderRelation": {
      "type": "enum",
      "view": "export:views/export-configurator-item/fields/sort-order-relation",
      "required": false,
      "options": [
        "ASC",
        "DESC"
      ],
      "default": "ASC"
    },
    "fixedValue": {
      "type": "varchar",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "type",
              "value": "Fixed value"
            }
          ]
        }
      }
    },
    "previousItem": {
      "type": "enum",
      "view": "export:views/export-configurator-item/fields/previous-item",
      "notStorable": true,
      "layoutMassUpdateDisabled": true,
      "filterDisabled": true,
      "importDisabled": true,
      "textFilterDisabled": true,
      "emHidden": true
    },
    "virtualFields": {
      "type": "jsonObject",
      "layoutListDisabled": true,
      "layoutListSmallDisabled": true,
      "layoutDetailDisabled": true,
      "layoutDetailSmallDisabled": true,
      "massUpdateDisabled": true,
      "filterDisabled": true,
      "exportDisabled": true,
      "importDisabled": true,
      "emHidden": true
    },
    "exportStaticListLabel": {
      "type": "bool",
      "view": "export:views/export-configurator-item/fields/export-static-list-label",
      "notStorable": true,
      "filterDisabled": true
    }
  },
  "links": {
    "exportFeed": {
      "type": "belongsTo",
      "foreign": "configuratorItems",
      "entity": "ExportFeed",
      "audited": false
    }
  },
  "collection": {
    "sortBy": "sortOrder",
    "asc": true
  },
  "indexes": {
    "name": {
      "columns": [
        "name",
        "deleted"
      ]
    }
  }
}