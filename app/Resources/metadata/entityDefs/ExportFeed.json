{
  "fields": {
    "name": {
      "type": "varchar",
      "required": true,
      "trim": true
    },
    "code": {
      "type": "varchar",
      "unique": true,
      "trim": true
    },
    "description": {
      "type": "text"
    },
    "limit": {
      "type": "int",
      "required": true,
      "default": 2000,
      "min": 1,
      "max": 10000
    },
    "separateJob": {
      "type": "bool"
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    },
    "createdBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "modifiedBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "type": {
      "type": "enum",
      "required": true,
      "optionsIds": [
        "simple"
      ],
      "options": [
        "simple"
      ],
      "default": "simple",
      "prohibitedEmptyValue": true
    },
    "isActive": {
      "notNull": true,
      "type": "bool"
    },
    "fileType": {
      "type": "enum",
      "required": true,
      "optionsIds": [
        "csv",
        "xlsx",
        "json",
        "xml",
        "sql"
      ],
      "options": [
        "csv",
        "xlsx",
        "json",
        "xml",
        "sql"
      ],
      "prohibitedEmptyValue": false,
      "default": "csv"
    },
    "isFileHeaderRow": {
      "type": "bool",
      "notStorable": true,
      "dataField": true,
      "default": true,
      "filterDisabled": true
    },
    "csvFieldDelimiter": {
      "type": "enum",
      "optionsIds": [
        ";",
        ",",
        "\\t"
      ],
      "options": [
        ";",
        ",",
        "\\t"
      ],
      "default": ";",
      "notStorable": true,
      "dataField": true,
      "view": "export:views/export-feed/fields/field-delimiter",
      "prohibitedEmptyValue": true,
      "filterDisabled": true
    },
    "csvTextQualifier": {
      "type": "enum",
      "optionsIds": [
        "doubleQuote",
        "singleQuote"
      ],
      "options": [
        "doubleQuote",
        "singleQuote"
      ],
      "default": "doubleQuote",
      "notStorable": true,
      "dataField": true,
      "prohibitedEmptyValue": true,
      "filterDisabled": true
    },
    "entity": {
      "type": "varchar",
      "required": false,
      "notStorable": true,
      "dataField": true,
      "view": "export:views/export-feed/fields/entity",
      "filterDisabled": true,
      "default": "Product"
    },
    "convertCollectionToString": {
      "type": "bool",
      "notStorable": true,
      "default": true,
      "dataField": true,
      "tooltip": true,
      "filterDisabled": true
    },
    "delimiter": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "~",
      "filterDisabled": true
    },
    "replaceAttributeValues": {
      "type": "bool",
      "notStorable": true,
      "default": true,
      "dataField": true,
      "tooltip": true,
      "filterDisabled": true
    },
    "convertRelationsToString": {
      "type": "bool",
      "notStorable": true,
      "default": true,
      "dataField": true,
      "tooltip": true,
      "filterDisabled": true
    },
    "fieldDelimiterForRelation": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "|",
      "filterDisabled": true
    },
    "emptyValue": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "",
      "filterDisabled": true,
      "tooltip": true
    },
    "nullValue": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "Null",
      "filterDisabled": true,
      "tooltip": true
    },
    "markForNoRelation": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "Null",
      "filterDisabled": true,
      "tooltip": true
    },
    "data": {
      "type": "jsonObject",
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "layoutMassUpdateDisabled": true,
      "filterDisabled": true
    },
    "configuratorItems": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "layoutMassUpdateDisabled": true,
      "noLoad": true
    },
    "exportJobs": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "layoutMassUpdateDisabled": true,
      "noLoad": true,
      "importDisabled": true
    },
    "sortOrderField": {
      "type": "varchar",
      "required": false,
      "view": "export:views/export-feed/fields/sort-order-field"
    },
    "sortOrderDirection": {
      "type": "enum",
      "required": false,
      "optionsIds": [
        "ASC",
        "DESC"
      ],
      "options": [
        "ASC",
        "DESC"
      ]
    },
    "originTemplateName": {
      "type": "enum",
      "view": "export:views/export-feed/fields/origin-template-name",
      "layoutListDisabled": true
    },
    "isTemplateEditable": {
      "type": "bool",
      "default": false
    },
    "originTemplate": {
      "type": "text",
      "rowsMax": 20,
      "useDisabledTextareaInViewMode": true,
      "notStorable": true,
      "readOnly": true,
      "filterDisabled": true
    },
    "template": {
      "type": "text",
      "useDisabledTextareaInViewMode": true,
      "rowsMax": 20,
      "required": false,
      "tooltip": true,
      "view": "export:views/export-feed/fields/template",
      "twigVariables": [
        "entities"
      ]
    },
    "lastStatus": {
      "type": "enum",
      "readOnly": true,
      "options": [
        "Pending",
        "Running",
        "Success",
        "Failed",
        "Canceled"
      ],
      "optionColors": [
        "00AFFF",
        "FFE208",
        "1DFF08",
        "FF0000",
        "DDDDDD"
      ]
    },
    "lastTime": {
      "type": "datetime"
    },
    "exportByMaxDepth": {
      "type": "enum",
      "required": false,
      "filterDisabled": true,
      "default": "1",
      "notStorable": true,
      "dataField": true,
      "prohibitedEmptyValue": true,
      "tooltip": true,
      "optionsIds": [
        "1",
        "2"
      ],
      "options": [
        "1",
        "2"
      ]
    },
    "folder": {
      "type": "link"
    },
    "locale": {
      "type": "link",
      "entity": "Locale",
      "required": true
    },
    "fileNameMask": {
      "type": "wysiwyg",
      "view": "views/fields/script",
      "twigVariables": [
        "feed",
        "filename",
        "interation"
      ]
    },
    "useQuoteForAll": {
      "type": "bool",
      "tooltip": true
    }
  },
  "links": {
    "createdBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "modifiedBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "configuratorItems": {
      "type": "hasMany",
      "foreign": "exportFeed",
      "entity": "ExportConfiguratorItem",
      "audited": false
    },
    "exportJobs": {
      "type": "hasMany",
      "foreign": "exportFeed",
      "entity": "ExportJob"
    },
    "folder": {
      "type": "belongsTo",
      "entity": "Folder"
    }
  },
  "collection": {
    "sortBy": "createdAt",
    "asc": false
  },
  "indexes": {
    "name": {
      "columns": [
        "name",
        "deleted"
      ]
    },
    "ownerUser": {
      "columns": [
        "ownerUserId",
        "deleted"
      ]
    },
    "assignedUser": {
      "columns": [
        "assignedUserId",
        "deleted"
      ]
    }
  }
}
