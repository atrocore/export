{
  "fields": {
    "name": {
      "type": "varchar",
      "required": true,
      "trim": true
    },
    "code": {
      "type": "varchar",
      "unique": true,
      "trim": true
    },
    "description": {
      "type": "text"
    },
    "limit": {
      "type": "int",
      "required": true,
      "default": 2000,
      "min": 1,
      "max": 10000,
      "tooltip": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        }
      }
    },
    "maxWorkers": {
      "type": "int",
      "min": 1,
      "tooltip": true
    },
    "separateJob": {
      "type": "bool",
      "tooltip": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        }
      }
    },
    "replaceExistingFile": {
      "type": "bool",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isFalse",
              "attribute": "separateJob"
            },
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        }
      }
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    },
    "createdBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "modifiedBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "type": {
      "type": "enum",
      "required": true,
      "conditionalProperties": {
        "protected": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "id"
            }
          ]
        }
      }
    },
    "isActive": {
      "notNull": true,
      "type": "bool"
    },
    "fileType": {
      "type": "varchar",
      "view": "export:views/export-feed/fields/file-type"
    },
    "isFileHeaderRow": {
      "type": "bool",
      "notStorable": true,
      "dataField": true,
      "default": true,
      "filterDisabled": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            }
          ]
        }
      }
    },
    "csvFieldDelimiter": {
      "type": "enum",
      "options": [
        ";",
        ",",
        "\\t"
      ],
      "default": ";",
      "notStorable": true,
      "dataField": true,
      "view": "export:views/export-feed/fields/field-delimiter",
      "filterDisabled": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "fileType",
              "value": "csv"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "fileType",
              "value": "csv"
            }
          ]
        }
      }
    },
    "csvTextQualifier": {
      "type": "enum",
      "options": [
        "doubleQuote",
        "singleQuote"
      ],
      "default": "doubleQuote",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "fileType",
              "value": "csv"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "fileType",
              "value": "csv"
            }
          ]
        }
      }
    },
    "entity": {
      "type": "varchar",
      "required": false,
      "notStorable": true,
      "dataField": true,
      "view": "export:views/export-feed/fields/entity",
      "filterDisabled": true,
      "default": "Product",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        }
      }
    },
    "convertCollectionToString": {
      "type": "bool",
      "notStorable": true,
      "default": true,
      "dataField": true,
      "tooltip": true,
      "filterDisabled": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            }
          ]
        },
        "readOnly": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "type",
              "value": [
                "simple"
              ]
            }
          ]
        }
      }
    },
    "delimiter": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "~",
      "filterDisabled": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            },
            {
              "type": "isTrue",
              "attribute": "convertCollectionToString"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            },
            {
              "type": "isTrue",
              "attribute": "convertCollectionToString"
            }
          ]
        }
      }
    },
    "convertRelationsToString": {
      "type": "bool",
      "notStorable": true,
      "default": true,
      "dataField": true,
      "tooltip": true,
      "filterDisabled": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            }
          ]
        },
        "readOnly": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "type",
              "value": [
                "simple"
              ]
            }
          ]
        }
      }
    },
    "fieldDelimiterForRelation": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "|",
      "filterDisabled": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            },
            {
              "type": "isTrue",
              "attribute": "convertRelationsToString"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            },
            {
              "type": "isTrue",
              "attribute": "convertRelationsToString"
            }
          ]
        }
      }
    },
    "emptyValue": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "",
      "filterDisabled": true,
      "tooltip": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            },
            {
              "type": "in",
              "attribute": "type",
              "value": [
                "simple",
                "ftp"
              ]
            }
          ]
        }
      }
    },
    "nullValue": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "Null",
      "filterDisabled": true,
      "tooltip": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            },
            {
              "type": "in",
              "attribute": "type",
              "value": [
                "simple",
                "ftp"
              ]
            }
          ]
        }
      }
    },
    "markForNoRelation": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "Null",
      "filterDisabled": true,
      "tooltip": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            }
          ]
        }
      }
    },
    "markForUnlinkedAttribute": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "default": "N/A",
      "filterDisabled": true,
      "tooltip": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            }
          ]
        }
      }
    },
    "data": {
      "type": "jsonObject",
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "layoutMassUpdateDisabled": true,
      "filterDisabled": true
    },
    "configuratorItems": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "layoutMassUpdateDisabled": true,
      "noLoad": true
    },
    "exportJobs": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "layoutMassUpdateDisabled": true,
      "noLoad": true,
      "importDisabled": true
    },
    "sortOrderField": {
      "type": "varchar",
      "required": false,
      "view": "export:views/export-feed/fields/sort-order-field",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        }
      }
    },
    "sortOrderDirection": {
      "type": "enum",
      "required": false,
      "options": [
        "ASC",
        "DESC"
      ],
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        }
      }
    },
    "originTemplateName": {
      "type": "enum",
      "view": "export:views/export-feed/fields/origin-template-name",
      "layoutListDisabled": true
    },
    "isTemplateEditable": {
      "type": "bool",
      "default": false,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "originTemplate"
            },
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "json",
                "xml",
                "sql"
              ]
            }
          ]
        }
      }
    },
    "originTemplate": {
      "type": "text",
      "rowsMax": 20,
      "useDisabledTextareaInViewMode": true,
      "notStorable": true,
      "readOnly": true,
      "filterDisabled": true,
      "view": "views/fields/script",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "json",
                "xml",
                "sql"
              ]
            },
            {
              "type": "isNotEmpty",
              "attribute": "originTemplate"
            }
          ]
        }
      }
    },
    "template": {
      "type": "text",
      "useDisabledTextareaInViewMode": true,
      "rowsMax": 20,
      "required": false,
      "tooltip": true,
      "view": "export:views/export-feed/fields/template",
      "twigVariables": [
        "entities"
      ],
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "json",
                "xml",
                "sql"
              ]
            }
          ]
        },
        "readOnly": {
          "conditionGroup": [
            {
              "type": "isFalse",
              "attribute": "isTemplateEditable"
            },
            {
              "type": "isNotEmpty",
              "attribute": "originTemplate"
            }
          ]
        }
      }
    },
    "lastStatus": {
      "type": "enum",
      "readOnly": true,
      "options": [
        "Pending",
        "Running",
        "Success",
        "Failed",
        "Canceled"
      ],
      "optionColors": [
        "b5e8ff",
        "fff078",
        "8fff87",
        "ff6262",
        "eeeeee"
      ]
    },
    "lastTime": {
      "type": "datetime"
    },
    "exportByMaxDepth": {
      "type": "enum",
      "required": false,
      "filterDisabled": true,
      "default": "1",
      "notStorable": true,
      "dataField": true,
      "tooltip": true,
      "options": [
        "1",
        "2"
      ],
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "xlsx",
                "csv"
              ]
            }
          ]
        }
      }
    },
    "folder": {
      "type": "link",
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "type",
              "value": [
                "simple"
              ]
            }
          ]
        }
      }
    },
    "locale": {
      "type": "link",
      "entity": "Locale",
      "required": false,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "fileType"
            }
          ]
        }
      }
    },
    "fileNameMask": {
      "type": "wysiwyg",
      "view": "views/fields/script",
      "twigVariables": [
        "feed",
        "filename",
        "interation"
      ],
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "type",
              "value": [
                "simple"
              ]
            }
          ]
        }
      }
    },
    "useQuoteForAll": {
      "type": "bool",
      "tooltip": true,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "fileType",
              "value": [
                "csv"
              ]
            }
          ]
        }
      }
    }
  },
  "links": {
    "createdBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "modifiedBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "configuratorItems": {
      "type": "hasMany",
      "foreign": "exportFeed",
      "entity": "ExportConfiguratorItem",
      "audited": false
    },
    "exportJobs": {
      "type": "hasMany",
      "foreign": "exportFeed",
      "entity": "ExportJob"
    },
    "folder": {
      "type": "belongsTo",
      "entity": "Folder"
    }
  },
  "collection": {
    "sortBy": "createdAt",
    "asc": false
  },
  "indexes": {
    "name": {
      "columns": [
        "name",
        "deleted"
      ]
    }
  }
}
